{
  "name": "rey30_magestic_card",
  "version": "1.0.0",
  "description": "MVP backend para Rey30 Mayestic Card",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "reycad:dev": "vite --config reycad/vite.config.ts",
    "reycad:check": "tsc -p reycad/tsconfig.json --noEmit",
    "reycad:build": "vite build --config reycad/vite.config.ts",
    "reycad:export:play": "tsx scripts/build-reycad-play-package.ts",
    "reycad:build:play": "npm run reycad:build && npm run reycad:export:play",
    "test:integration:reycad:pie": "tsx --test tests/integration/reycad-play-package.integration.test.ts tests/integration/reycad-play-session.integration.test.ts",
    "reycad:ci:play-gate": "npm run reycad:build:play && npm run test:integration:reycad:pie",
    "reycad:preview": "vite preview --config reycad/vite.config.ts",
    "reycad:benchmark": "tsx scripts/benchmark-reycad-runtime.ts",
    "reycad:benchmark:ci": "tsx scripts/benchmark-reycad-runtime.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "check": "tsc --noEmit",
    "test:unit": "tsx --test tests/unit/card-validator.test.ts tests/unit/moderation.test.ts tests/unit/rate-limit.test.ts tests/unit/vault-crypto.test.ts tests/unit/card-engine.test.ts tests/unit/reycad-commands.test.ts tests/unit/reycad-engine-core.test.ts tests/unit/reycad-quality-store.test.ts tests/unit/reycad-job-system.test.ts tests/unit/reycad-frame-budget-scheduler.test.ts tests/unit/reycad-render-tuning.test.ts tests/unit/reycad-asset-manager.test.ts tests/unit/ai-policy-filtering.test.ts tests/unit/reymeshy-sidecar.test.ts tests/unit/vram-sentinel.test.ts tests/unit/reycad-play-session-manager.test.ts tests/unit/reycad-play-session-store.test.ts tests/unit/reycad-play-session-export.test.ts tests/unit/hybrid-runtime-control.test.ts",
    "test:integration": "node scripts/test-integration-auto.cjs",
    "test:integration:sqlite": "npm run build && tsx --test tests/integration/auth-me.integration.test.ts tests/integration/agents-config-versioning.integration.test.ts tests/integration/agent-tool-runs-history.integration.test.ts tests/integration/skills-promotion-template-governance.integration.test.ts tests/integration/me-ai-config.integration.test.ts tests/integration/memory-project-ownership.integration.test.ts tests/integration/asset-vault.integration.test.ts tests/integration/training-jobs-runner.integration.test.ts tests/integration/training-worker-external.integration.test.ts tests/integration/admin-training-dlq.integration.test.ts tests/integration/admin-ops-metrics.integration.test.ts tests/integration/admin-ops-traces.integration.test.ts tests/integration/admin-vault-security.integration.test.ts tests/integration/admin-abuse-security.integration.test.ts tests/integration/sensitive-rate-limit.integration.test.ts tests/integration/training-limits.integration.test.ts tests/integration/training-worker-redis.integration.test.ts tests/integration/frontend-shell.integration.test.ts tests/integration/mcp-gateway.integration.test.ts tests/integration/mcp-hybrid-dispatch-jobs.integration.test.ts tests/integration/mcp-hybrid-status.integration.test.ts tests/integration/reymeshy-vram-guard.integration.test.ts tests/integration/reymeshy-jobs.integration.test.ts tests/integration/reymeshy-e2e.integration.test.ts tests/integration/training-idempotency-cancel.integration.test.ts tests/integration/training-timeout.integration.test.ts tests/integration/training-stage-timeout.integration.test.ts tests/integration/cards-marketplace-guards.integration.test.ts tests/integration/cards-creator-editor.integration.test.ts tests/integration/duels-engine.integration.test.ts",
    "test:frontend": "npm run build && tsx --test tests/integration/frontend-shell.integration.test.ts",
    "test:integration:redis": "npm run build && tsx --test tests/integration/training-worker-redis.integration.test.ts",
    "test:integration:postgres": "npm run build && tsx --test tests/integration/training-postgres-mirror.integration.test.ts",
    "smoke:test": "pwsh -NoProfile -File scripts/smoke-test.ps1",
    "smoke:gates": "pwsh -NoProfile -File scripts/smoke-gates.ps1",
    "smoke:projects": "pwsh -NoProfile -File scripts/smoke-projects.ps1",
    "smoke:training-profile": "pwsh -NoProfile -File scripts/smoke-training-profile.ps1",
    "smoke:agent-skills": "pwsh -NoProfile -File scripts/smoke-agent-skills.ps1",
    "smoke:policy-events": "pwsh -NoProfile -File scripts/smoke-policy-events.ps1",
    "smoke:ai-policy-flow": "pwsh -NoProfile -File scripts/smoke-ai-policy-flow.ps1",
    "smoke:core-regression": "pwsh -NoProfile -File scripts/smoke-core-regression.ps1",
    "smoke:reycad:pie": "pwsh -NoProfile -File scripts/smoke-reycad-pie.ps1",
    "smoke:transactions": "pwsh -NoProfile -File scripts/smoke-transactions.ps1",
    "security:scan:secrets": "node scripts/security-scan-secrets.cjs",
    "security:rotation:checklist": "node scripts/security-rotation-checklist.cjs",
    "db:migrate:sqlite-to-sqlserver": "node scripts/migrate-sqlite-to-sqlserver.cjs",
    "db:sqlserver:clean:all": "node scripts/sqlserver-clean-all.cjs",
    "db:sqlserver:clean:cards": "node scripts/sqlserver-clean-card-domain.cjs",
    "test:integration:sqlserver:cutover": "npm run build && tsx --test tests/integration/auth-me.integration.test.ts tests/integration/me-ai-config.integration.test.ts tests/integration/asset-vault.integration.test.ts tests/integration/mcp-gateway.integration.test.ts tests/integration/mcp-hybrid-dispatch-jobs.integration.test.ts tests/integration/mcp-hybrid-status.integration.test.ts tests/integration/reymeshy-jobs.integration.test.ts && npm run db:sqlserver:clean:cards && tsx --test tests/integration/cards-creator-editor.integration.test.ts && npm run db:sqlserver:clean:cards && tsx --test tests/integration/cards-marketplace-guards.integration.test.ts",
    "test:integration:sqlserver:full": "node scripts/test-integration-sqlserver-full.cjs",
    "smoke:all": "npm run smoke:test && npm run smoke:gates && npm run smoke:projects && npm run smoke:training-profile && npm run smoke:agent-skills && npm run smoke:policy-events && npm run smoke:ai-policy-flow && npm run smoke:core-regression && npm run smoke:transactions && npm run smoke:reycad:pie",
    "test": "npm run test:unit && npm run test:integration"
  },
  "keywords": [
    "cards",
    "game",
    "backend",
    "sqlite",
    "socketio"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "cors": "^2.8.6",
    "dockview": "^5.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "idb-keyval": "^6.2.2",
    "immer": "^11.1.4",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mssql": "^12.2.0",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "three": "^0.183.2",
    "three-bvh-csg": "^0.0.16",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.3.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "overrides": {
    "tar": "^7.5.8"
  }
}
