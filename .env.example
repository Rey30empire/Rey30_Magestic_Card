PORT=4000
JWT_SECRET=change_this_in_production
VAULT_SECRET=change_this_in_production_and_separate_from_jwt
VAULT_ACTIVE_KEY_ID=local-default
# VAULT_KEYRING=local-default:change_this_in_production_and_separate_from_jwt,old-key-id:legacy_secret
DB_PATH=./data/rey30.db
CREATIVE_POINTS_START=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
API_RATE_LIMIT_MAX_BUCKETS=50000
SENSITIVE_RATE_LIMIT_WINDOW_MS=60000
SENSITIVE_RATE_LIMIT_MAX_PER_USER=40
SENSITIVE_RATE_LIMIT_MAX_PER_TOKEN=80
SENSITIVE_RATE_LIMIT_MAX_BUCKETS=50000
ABUSE_RISK_WINDOW_MS=900000
ABUSE_RISK_BLOCK_THRESHOLD=100
ABUSE_RISK_BLOCK_MS=600000
ABUSE_RISK_INCIDENT_COOLDOWN_MS=300000
TEMPLATE_QUALITY_MIN_SCORE=45
MARKETPLACE_APP_VERSION=1.0.0
OPS_ALERT_CARDS_409_15M=10
OPS_ALERT_MARKETPLACE_409_15M=10
OPS_ALERT_RATE_LIMIT_429_15M=30
OPS_ALERT_HTTP_5XX_15M=5
OPS_ALERT_TRAINING_QUEUE_DEPTH=100
OPS_ALERT_TRAINING_FAILURE_RATE_15M=40
OPS_METRICS_FLUSH_MS=15000
OPS_TRACE_MAX_SPANS=5000
TRAINING_RUNNER_MODE=inline
TRAINING_WORKER_POLL_MS=500
TRAINING_JOB_MAX_RUNTIME_MS=0
TRAINING_QUEUE_BACKEND=local
TRAINING_QUEUE_NAME=training-jobs
TRAINING_WORKER_CONCURRENCY=2
TRAINING_QUEUE_ATTEMPTS=5
TRAINING_QUEUE_BACKOFF_MS=1000
TRAINING_DLQ_NAME=training-jobs-dlq
TRAINING_DLQ_ALERT_THRESHOLD=10
TRAINING_MAX_ACTIVE_PER_USER=10
TRAINING_MAX_ACTIVE_GLOBAL=500
# REDIS_URL=redis://127.0.0.1:6379
# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/rey30_test
POSTGRES_DUAL_WRITE=false
POSTGRES_POOL_MAX=5
LLM_REQUEST_TIMEOUT_MS=15000
LLM_MAX_RETRIES=1
LLM_ALLOW_HTTP=false
LLM_ALLOW_LOCAL_ENDPOINTS=false
LLM_ALLOWED_HOSTS=api.openai.com,openrouter.ai,api.groq.com,api.anthropic.com
CORS_ORIGINS=http://127.0.0.1:4000,http://localhost:4000,http://127.0.0.1:4173,http://localhost:4173
SOCKET_CORS_ORIGINS=http://127.0.0.1:4000,http://localhost:4000,http://127.0.0.1:4173,http://localhost:4173
TRUST_PROXY=false
